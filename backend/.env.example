# Copy to backend/.env and fill in.
PORT=4000

# Chain (read-only provider — backend signs NOTHING; MetaMask signs writes on the frontend).
RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
CONTRACT_ADDRESS=

# Database (libSQL).
# Local dev: a file. Production/Vercel: set TURSO_DATABASE_URL + TURSO_AUTH_TOKEN instead.
DB_FILE=file:./certverify.db
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
